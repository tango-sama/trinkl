rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Yalidine API credentials (apiId, apiToken). Never readable by any
    // client — only the Cloud Function reads them via the Admin SDK, which
    // bypasses these rules. Writable so the admin panel can set them.
    match /private/{document=**} {
      allow read: if false;
      allow write: if true;
    }

    // Synced carrier fee grids — readable by the storefront, written only by
    // the Cloud Function (Admin SDK bypasses these rules).
    match /delivery_fees/{document=**}     { allow read: if true; allow write: if false; }

    // Public storefront + admin collections (open, as before).
    match /products/{document=**}         { allow read, write: if true; }
    match /categories/{document=**}        { allow read, write: if true; }
    match /featured_products/{document=**} { allow read, write: if true; }
    match /site_settings/{document=**}     { allow read, write: if true; }
    match /orders/{document=**}            { allow read, write: if true; }
    match /messages/{document=**}          { allow read, write: if true; }
  }
}
